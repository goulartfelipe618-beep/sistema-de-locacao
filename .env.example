# ==========================================================================
# ERP Locadora — Variáveis de ambiente (VPS / produção)
#
# Na VPS:
#   cp .env.example .env
#   nano .env   # preencha TODOS os valores marcados como obrigatórios
#
# NUNCA versionar o arquivo `.env` real.
# Hosts POSTGRES_HOST/REDIS_HOST já apontam para os serviços do Compose.
# ==========================================================================

# --- Aplicação ---
APP_NAME="ERP Locadora"
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true
TIMEZONE=America/Sao_Paulo
HTTP_PORT=80
IMAGE_TAG=latest
WEB_CONCURRENCY=2
CELERY_CONCURRENCY=4
CELERY_LOG_LEVEL=INFO
# No boot do comando `web` (recomendado no Easypanel): cria tabelas + admin.
AUTO_MIGRATE=true
AUTO_SEED=true

# --- Segurança (OBRIGATÓRIO gerar valores fortes) ---
# python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_gere_com_secrets_token_urlsafe_64
SESSION_COOKIE_NAME=erp_session
SESSION_MAX_AGE_SECONDS=43200
SESSION_HTTPS_ONLY=true
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
PASSWORD_MIN_LENGTH=12
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
# Nome do serviço Nginx no Compose (cabeçalhos X-Forwarded-*).
TRUSTED_PROXY_IPS=nginx

# --- PostgreSQL (superusuário do container + role da aplicação) ---
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME_senha_forte_superuser
POSTGRES_DB=erp
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=erp_app
POSTGRES_PASSWORD=CHANGE_ME_senha_forte_app
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=CHANGE_ME_senha_forte_redis

# --- Celery ---
CELERY_BROKER_DB=1
CELERY_RESULT_DB=2

# --- Cloudflare R2 (S3 compatível) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=erp-locadora
R2_ENDPOINT_URL=
R2_PUBLIC_BASE_URL=
R2_PRESIGN_EXPIRE_SECONDS=900

# --- Multiempresa / SaaS ---
DEFAULT_TENANT_SLUG=matriz
ENFORCE_RLS=true

# --- Seed inicial (obrigatório em production/staging) ---
SEED_ADMIN_EMAIL=admin@suaempresa.com
SEED_ADMIN_PASSWORD=CHANGE_ME_senha_forte_admin
SEED_ADMIN_NAME=Administrador
SEED_TENANT_NAME="Locadora Matriz LTDA"
# Usuários demo por setor (vendedor, operador, financeiro, diretoria) — só em development
SEED_DEMO_USERS=true
# Cadastros fictícios completos (clientes, frota, reservas, contratos, etc.)
SEED_DEMO_DATA=true
SEED_DEMO_COUNT=7

# --- Supabase (opcional — site/API externa ou Postgres remoto) ---
SUPABASE_PROJECT_REF=tchbfavyhhnuhpssqnih
SUPABASE_URL=https://tchbfavyhhnuhpssqnih.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Settings → Database → Connection string (pooler). Exemplo região sa-east-1:
# SUPABASE_DB_URL=postgresql://postgres.SEU_REF:SENHA@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

# --- Auditoria / Retenção ---
AUDIT_RETENTION_DAYS=730
LOG_RETENTION_DAYS=90

# --- CORS (API REST — domínios reais dos futuros consumidores) ---
CORS_ORIGINS=https://suaempresa.com

# --- Site institucional (serviço separado — white-label) ---
# O site conversa com o ERP pela rede interna (Docker/Easypanel), sem expor API Key no browser.
SITE_HTTP_PORT=8080
SITE_PUBLIC_URL=http://localhost:8080
SITE_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# URL interna do ERP (Compose: http://web:8000 | Easypanel: http://erp-locadora:8000)
ERP_INTERNAL_URL=http://web:8000
# Chave gerada no ERP: Integrações → API Pública (escopos catalogo, veiculos, pricing, reservas)
SITE_ERP_API_KEY=erp_COLE_SUA_CHAVE_AQUI
# Deve coincidir com DEFAULT_TENANT_SLUG deste deploy
# ERP_TENANT_SLUG é lido pelo BFF do site (alias: use DEFAULT_TENANT_SLUG no Easypanel)

# --- Notificações (e-mail / SMS) ---
# simulador = apenas log (dev); smtp = envio real
NOTIFICATION_EMAIL_PROVIDER=simulador
NOTIFICATION_SMS_PROVIDER=simulador
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
