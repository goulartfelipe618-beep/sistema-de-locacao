# =============================================================================
# Site Rodavia — BFF + variáveis (copie para site/.env)
# =============================================================================

# ERP (URL do backend — Easypanel ou domínio técnico futuro)
ERP_BASE_URL=https://loca-erp-locadora.eal7ix.easypanel.host
ERP_API_KEY=erp_COLE_SUA_CHAVE_AQUI
ERP_TENANT_SLUG=rodavia

# Site público — ATUALIZE quando apontar seu domínio (ex: https://www.sualocadora.com.br)
SITE_PUBLIC_URL=http://localhost:8080
SITE_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# BFF (porta interna; em produção o Nginx faz proxy /bff → 8090)
BFF_HOST=0.0.0.0
BFF_PORT=8090
