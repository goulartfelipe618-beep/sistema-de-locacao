# Site + BFF — variáveis (copie para a raiz do repo: cp .env.example .env)
#
# Dev local (ERP em produção Easypanel):
#   ERP_BASE_URL=https://loca-erp-locadora.eal7ix.easypanel.host
#   ERP_TENANT_SLUG=matriz
#   ERP_API_KEY=<chave catalogo:read do ERP>
#
# Docker Compose / Easypanel (rede interna):
#   ERP_INTERNAL_URL=http://erp-locadora:8000
#   ERP_TENANT_SLUG=matriz
#   ERP_API_KEY=<chave catalogo:read>

ERP_BASE_URL=https://loca-erp-locadora.eal7ix.easypanel.host
ERP_INTERNAL_URL=
ERP_TENANT_SLUG=matriz
ERP_API_KEY=erp_COLE_SUA_CHAVE_CATALOGO_READ_AQUI

# Opcional: uma chave por escopo (Integrações → API Pública no ERP)
# ERP_API_KEY_CATALOGO=
# ERP_API_KEY_DISPONIBILIDADE=
# ERP_API_KEY_VEICULOS=
# ERP_API_KEY_PRICING=
# ERP_API_KEY_RESERVAS=

# Webhook do formulário de atendimento (chat flutuante) — copie de Integrações → API Pública no ERP
SITE_ATENDIMENTO_WEBHOOK_URL=https://loca-erp-locadora.eal7ix.easypanel.host/api/v1/public/webhooks/atendimento?token=COLE_O_TOKEN_DO_ERP

SITE_PUBLIC_URL=http://localhost:8080
SITE_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
