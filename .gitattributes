# Força LF (Unix) — obrigatório para execução em VPS Linux / containers.
* text=auto eol=lf
*.sh text eol=lf
docker/entrypoint.sh text eol=lf
docker/postgres/*.sh text eol=lf
scripts/**/*.sh text eol=lf

# Binários
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
